# Add directories or file patterns to ignore during indexing (e.g. foo/ or *.csv)
# 代码审查时忽略的目录和文件

# 测试文件
*_test.go
*.test.ts
*.test.js
*.spec.ts
*.spec.js
**/test_*.go
**/*_test_*.go
**/0_0_test_init.go
__tests__/**
test/**
tests/**

# 依赖目录
**/vendor/**
**/node_modules/**

# 构建产物
**/dist/**
**/build/**
**/target/**
**/out/**
**/bin/**
**/obj/**

# 版本控制
**/.git/**
**/.svn/**
**/.hg/**

# IDE 配置
**/.idea/**
**/.vscode/**
**/.vs/**

# 测试覆盖率
**/coverage/**
**/.nyc_output/**

# 临时文件
**/tmp/**
**/temp/**

# 工具和脚本目录
tools/**
scripts/**
**/tools/**
**/scripts/**

# 数据访问层和模型层（自动生成或样板代码）
**/repo/**
**/model/**

# 压缩文件和映射文件
**/*.min.js
**/*.min.css
**/*.map

# 系统文件
**/.DS_Store
**/Thumbs.db
