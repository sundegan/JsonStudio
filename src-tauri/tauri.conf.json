{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Json Studio",
  "version": "1.0.0",
  "identifier": "com.jsonstudio.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Json Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",      
      "dmg",       
      "appimage"   
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Fast, modern, and efficient JSON desktop tool",
    "longDescription": "A modern JSON desktop application built with Tauri 2.0 and Rust, providing common features like formatting, compression, escaping, and comparison",
    "copyright": "Copyright © 2025 Json Studio",
    "category": "DeveloperTool",
    "fileAssociations": [
      {
        "ext": [
          "json"
        ],
        "name": "JSON Document",
        "role": "Editor",
        "rank": "Owner",
        "contentTypes": [
          "public.json"
        ]
      }
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
